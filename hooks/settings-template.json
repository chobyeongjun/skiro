{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/Desktop/ARLAB/skiro/bin/skiro-hook-complexity"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/Desktop/ARLAB/skiro/bin/skiro-hook-gate"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/Desktop/ARLAB/skiro/bin/skiro-hook-session"
          }
        ]
      }
    ]
  }
}

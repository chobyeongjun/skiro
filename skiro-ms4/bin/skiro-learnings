#!/usr/bin/env bash
# skiro-learnings v1.1 — learnings JSONL 관리
# Commands: add | list | search | count | promote | migrate

LEARNINGS_FILE="${SKIRO_LEARNINGS:-$(pwd)/.skiro/learnings.jsonl}"
CMD="${1:-help}"
shift || true
mkdir -p "$(dirname "$LEARNINGS_FILE")"
touch "$LEARNINGS_FILE"

if [[ "$CMD" == "add" ]]; then
  python3 - "$LEARNINGS_FILE" "$@" <<'PYEOF'
import json, sys
from datetime import date
lf = sys.argv[1]; args = sys.argv[2:]
kv = {}; i = 0
while i < len(args):
    if args[i].startswith('--') and i+1 < len(args):
        kv[args[i][2:]] = args[i+1]; i += 2
    else: i += 1
category = kv.get('category', ''); severity = kv.get('severity', 'INFO')
lesson = kv.get('lesson', '');     context  = kv.get('context', 'manual')
if not category: sys.exit("ERROR: --category 필수")
if not lesson:   sys.exit("ERROR: --lesson 필수")
entries = []
for line in open(lf):
    try: entries.append(json.loads(line.strip()))
    except: pass
found = False
for e in entries:
    if e.get('lesson') == lesson:
        e['count'] = e.get('count', 1) + 1
        e['last_seen'] = date.today().isoformat()
        found = True
        print(f"Updated: [{e['severity']}/{e['category']}] count → {e['count']}")
        break
if not found:
    entries.append({'date': date.today().isoformat(), 'skill': 'manual', 'tier': 'N/A',
        'category': category, 'severity': severity, 'lesson': lesson,
        'context': context, 'count': 1})
    print(f"Added: [{severity}/{category}] {lesson}")
with open(lf, 'w') as f:
    for e in entries:
        f.write(json.dumps(e, ensure_ascii=False) + '\n')
PYEOF

elif [[ "$CMD" == "list" ]]; then
  python3 - "$LEARNINGS_FILE" "$@" <<'PYEOF'
import json, sys
lf = sys.argv[1]; args = sys.argv[2:]
kv = {}; i = 0
while i < len(args):
    if args[i].startswith('--') and i+1 < len(args):
        kv[args[i][2:]] = args[i+1]; i += 2
    else: i += 1
entries = []
for line in open(lf):
    try: entries.append(json.loads(line.strip()))
    except: pass
if kv.get('category'): entries = [e for e in entries if e.get('category') == kv['category']]
if kv.get('severity'): entries = [e for e in entries if e.get('severity') == kv['severity']]
n = int(kv.get('last', 0))
if n > 0: entries = entries[-n:]
for e in entries:
    cnt = f" x{e['count']}" if e.get('count', 1) > 1 else ""
    print(f"[{e.get('date','?')}][{e.get('severity','?')}/{e.get('category','?')}]{cnt} {e.get('lesson','')}")
    ctx = e.get('context', 'manual')
    if ctx not in ('manual', 'N/A', ''): print(f"  ctx: {ctx}")
print(f"\nTotal: {len(entries)}")
PYEOF

elif [[ "$CMD" == "search" ]]; then
  KW="${1:-}"; [[ -z "$KW" ]] && { echo "Usage: skiro-learnings search <keyword>"; exit 1; }
  python3 - "$LEARNINGS_FILE" "$KW" <<'PYEOF'
import json, sys
lf, kw = sys.argv[1], sys.argv[2].lower(); out = []
for line in open(lf):
    try:
        d = json.loads(line.strip())
        if any(kw in str(d.get(k, '')).lower() for k in ['lesson', 'context', 'category', 'severity']):
            out.append(d)
    except: pass
for e in out:
    cnt = f" x{e['count']}" if e.get('count', 1) > 1 else ""
    print(f"[{e.get('severity','?')}/{e.get('category','?')}]{cnt} {e.get('lesson','')}")
print(f"\n{len(out)} results for '{sys.argv[2]}'")
PYEOF

elif [[ "$CMD" == "count" ]]; then
  python3 - "$LEARNINGS_FILE" <<'PYEOF'
import json, sys, collections
entries = []
for line in open(sys.argv[1]):
    try: entries.append(json.loads(line.strip()))
    except: pass
by_cat = collections.Counter(e.get('category', '?') for e in entries)
by_sev = collections.Counter(e.get('severity', '?') for e in entries)
print(f"Total entries: {len(entries)}")
print("\nBy category:")
for k, v in sorted(by_cat.items()): print(f"  {k}: {v}")
print("\nBy severity:")
for k, v in sorted(by_sev.items()): print(f"  {k}: {v}")
PYEOF

elif [[ "$CMD" == "promote" ]]; then
  THRESHOLD="${1:-3}"
  python3 - "$LEARNINGS_FILE" "$THRESHOLD" <<'PYEOF'
import json, sys
lf, threshold = sys.argv[1], int(sys.argv[2])
entries = []
for line in open(lf):
    try: entries.append(json.loads(line.strip()))
    except: pass
cands = [e for e in entries if e.get('count', 1) >= threshold]
if not cands:
    print(f"승격 후보 없음 (threshold={threshold}회)")
else:
    print(f"[PROMOTE 제안] {len(cands)}개 항목이 {threshold}회 이상 반복됨")
    print("CHECKLIST.md 추가 권장:\n")
    for e in cands:
        print(f"  [{e.get('category','?').upper()}] (x{e.get('count',1)}) [ ] {e.get('lesson','')}")
    print("\n→ CHECKLIST.md 해당 섹션에 추가하세요")
PYEOF

elif [[ "$CMD" == "migrate" ]]; then
  SRC="${1:-}"; [[ -z "$SRC" || ! -f "$SRC" ]] && { echo "ERROR: 파일 없음: $SRC"; exit 1; }
  python3 - "$LEARNINGS_FILE" "$SRC" <<'PYEOF'
import json, sys
from datetime import date
lf, src = sys.argv[1], sys.argv[2]; count = 0
with open(src) as f, open(lf, 'a') as fo:
    for line in f:
        line = line.strip()
        if not line or line.startswith('#'): continue
        fo.write(json.dumps({'date': date.today().isoformat(), 'skill': 'migrated',
            'tier': 'N/A', 'category': 'process', 'severity': 'INFO',
            'lesson': line, 'context': f'migrated from {src}', 'count': 1},
            ensure_ascii=False) + '\n')
        count += 1
print(f"Migrated {count} entries to {lf}")
PYEOF

else
  echo "Usage: skiro-learnings <cmd> [opts]"
  echo "Commands: add | list | search | count | promote | migrate"
  echo "  add   --category <cat> --severity <sev> --lesson <text> [--context <ctx>]"
  echo "  list  [--category <cat>] [--last <N>] [--severity <sev>]"
  echo "  search <keyword>"
  echo "  count"
  echo "  promote [<threshold=3>]"
  echo "  migrate <old_flat_text_file>"
  echo "Categories: safety|control|hardware|software|protocol|process|experiment"
  echo "Severities: INFO|WARNING|CRITICAL"
  [[ "$CMD" != "help" && "$CMD" != "--help" ]] && exit 1
fi

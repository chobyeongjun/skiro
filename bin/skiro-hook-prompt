#!/bin/sh
# skiro-hook-prompt v3.1
# UserPromptSubmit hook
#
# v3.1:
#   - skiro-classify.py 분리 (heredoc truncation 완전 해결)
#   - python3 1회 호출 (v2: 3회 → ~3배 빠름)
#   - slow-path: 패턴 미감지 시 Claude context에 판단 주입

SKIRO_BIN="${SKIRO_BIN:-$HOME/skiro/bin}"
LEARNINGS="$SKIRO_BIN/skiro-learnings"
CLASSIFY="$SKIRO_BIN/skiro-classify.py"
[ -x "$LEARNINGS" ] || exit 0
[ -f "$CLASSIFY"  ] || exit 0

GLOBAL_SKIRO="$HOME/.skiro"
mkdir -p "$GLOBAL_SKIRO"
SKIRO_LEARNINGS="${SKIRO_LEARNINGS:-$GLOBAL_SKIRO/learnings.jsonl}"
export SKIRO_LEARNINGS

INPUT=$(cat 2>/dev/null || true)
[ -z "$INPUT" ] && exit 0

# ── python3 단일 호출: 파싱 + 분류 + hash 계산 ───────────────────
RESULT=$(echo "$INPUT" | python3 "$CLASSIFY" 2>/dev/null)
[ -z "$RESULT" ] && exit 0

MSG_HASH=$(echo "$RESULT"   | cut -d'|' -f1)
IS_PROBLEM=$(echo "$RESULT" | cut -d'|' -f2)
IS_SOLUTION=$(echo "$RESULT"| cut -d'|' -f3)
CATEGORY=$(echo "$RESULT"   | cut -d'|' -f4)
SEVERITY=$(echo "$RESULT"   | cut -d'|' -f5)
FIRST=$(echo "$RESULT"      | cut -d'|' -f6)

# 중복 방지
LAST_HASH="$GLOBAL_SKIRO/.last-prompt-hash"
if [ -n "$MSG_HASH" ] && [ -f "$LAST_HASH" ]; then
    [ "$(cat "$LAST_HASH" 2>/dev/null)" = "$MSG_HASH" ] && exit 0
fi
[ -n "$MSG_HASH" ] && echo "$MSG_HASH" > "$LAST_HASH"

TODAY=$(date +%Y-%m-%d)

# ── Fast-path: 패턴 명확히 매칭된 경우 즉시 저장 ─────────────────
if [ "$IS_PROBLEM" = "1" ] && [ "$IS_SOLUTION" = "0" ]; then
    [ -z "$FIRST" ] && exit 0
    "$LEARNINGS" add \
        --problem "$FIRST" \
        --category "$CATEGORY" \
        --severity "$SEVERITY" \
        --context "$TODAY hook-prompt" 2>/dev/null
    echo "[skiro] [?] $FIRST"
    exit 0
fi

if [ "$IS_SOLUTION" = "1" ]; then
    [ -z "$FIRST" ] && exit 0
    SOLVE_OUT=$("$LEARNINGS" solve --solution "$FIRST" 2>/dev/null)
    if echo "$SOLVE_OUT" | grep -q "unsolved"; then
        "$LEARNINGS" add \
            --problem "$FIRST" --solution "$FIRST" \
            --category "process" --severity "INFO" \
            --context "$TODAY hook-prompt(sol)" 2>/dev/null
    fi
    # promote --auto
    CHECKLIST=""
    GIT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || true)
    [ -n "$GIT_ROOT" ] && [ -f "$GIT_ROOT/CHECKLIST.md" ] && CHECKLIST="$GIT_ROOT/CHECKLIST.md"
    [ -n "${SKIRO_CHECKLIST:-}" ] && [ -f "${SKIRO_CHECKLIST:-}" ] && CHECKLIST="${SKIRO_CHECKLIST:-}"
    if [ -n "$CHECKLIST" ]; then
        SKIRO_CHECKLIST="$CHECKLIST" "$LEARNINGS" promote 3 --auto 2>/dev/null || true
    else
        "$LEARNINGS" promote 3 2>/dev/null || true
    fi
    echo "[skiro] [v] $FIRST"
    exit 0
fi

# ── Slow-path: 패턴 미감지 → 무출력 (MCP tool description이 Claude를 안내)
exit 0

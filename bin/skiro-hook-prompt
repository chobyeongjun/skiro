#!/bin/sh
# skiro-hook-prompt v4.1
# UserPromptSubmit hook — Reward/Punish 강화학습 + Vault 직접 읽기/쓰기
#
# 신호 감지:
#   - 문제 → vault에 기록 + 유사 교훈 검색
#   - 해결 → vault에서 미해결 항목 연결
#   - REWARD → "잘 돼", "완벽해" → 왜 잘 됐는지 기록
#   - PUNISH → "때문에 안 돼", "이유는" → 왜 안 됐는지 기록

SKIRO_BIN="${SKIRO_BIN:-$HOME/skiro/bin}"
LEARNINGS="$SKIRO_BIN/skiro-learnings"
CLASSIFY="$SKIRO_BIN/skiro-classify.py"
[ -x "$LEARNINGS" ] || exit 0
[ -f "$CLASSIFY"  ] || exit 0

GLOBAL_SKIRO="$HOME/.skiro"
mkdir -p "$GLOBAL_SKIRO"

INPUT=$(cat 2>/dev/null || true)
[ -z "$INPUT" ] && exit 0

# ── 분류 (v4.1: 6필드 → 8필드) ────────────────────────────────
RESULT=$(echo "$INPUT" | python3 "$CLASSIFY" 2>/dev/null)
[ -z "$RESULT" ] && exit 0

MSG_HASH=$(echo "$RESULT"    | cut -d'|' -f1)
IS_PROBLEM=$(echo "$RESULT"  | cut -d'|' -f2)
IS_SOLUTION=$(echo "$RESULT" | cut -d'|' -f3)
IS_REWARD=$(echo "$RESULT"   | cut -d'|' -f4)
IS_PUNISH=$(echo "$RESULT"   | cut -d'|' -f5)
CATEGORY=$(echo "$RESULT"    | cut -d'|' -f6)
SEVERITY=$(echo "$RESULT"    | cut -d'|' -f7)
FIRST=$(echo "$RESULT"       | cut -d'|' -f8)

# 중복 방지
LAST_HASH="$GLOBAL_SKIRO/.last-prompt-hash"
if [ -n "$MSG_HASH" ] && [ -f "$LAST_HASH" ]; then
    [ "$(cat "$LAST_HASH" 2>/dev/null)" = "$MSG_HASH" ] && exit 0
fi
[ -n "$MSG_HASH" ] && echo "$MSG_HASH" > "$LAST_HASH"

TODAY=$(date +%Y-%m-%d)

# ── REWARD: 잘 됐다 → 왜 잘 됐는지 기록 ────────────────────────
if [ "$IS_REWARD" = "1" ]; then
    [ -z "$FIRST" ] && exit 0
    "$LEARNINGS" reward \
        --what "$FIRST" \
        --why "auto-detected positive signal" \
        --category "$CATEGORY" \
        --context "$TODAY hook-prompt" 2>/dev/null
    echo "[skiro] [+R] $FIRST"
    exit 0
fi

# ── PUNISH: 원인 분석 → 왜 안 됐는지 기록 ──────────────────────
if [ "$IS_PUNISH" = "1" ]; then
    [ -z "$FIRST" ] && exit 0
    "$LEARNINGS" punish \
        --what "$FIRST" \
        --why "auto-detected negative cause analysis" \
        --category "$CATEGORY" \
        --context "$TODAY hook-prompt" 2>/dev/null

    # 유사 reward 검색 — 반대 사례가 있으면 표시
    KEYWORDS=$(echo "$FIRST" | python3 -c "
import sys, re
text = sys.stdin.read().lower()
stopwords = {'the','is','a','an','in','on','이','가','을','를','에','의','로','은','는','도','만','때문에','이유는','원인은','하면','안','못'}
words = re.findall(r'[a-zA-Z가-힣]{3,}', text)
print(' '.join([w for w in words if w not in stopwords][:3]))
" 2>/dev/null)
    for KW in $KEYWORDS; do
        REWARD_HIT=$("$LEARNINGS" search "$KW" 2>/dev/null | grep "REWARD" | head -1)
        if [ -n "$REWARD_HIT" ]; then
            echo "[skiro] [-P] $FIRST"
            echo "[skiro/learn] 반대 사례(REWARD) 발견:"
            echo "$REWARD_HIT"
            exit 0
        fi
    done
    echo "[skiro] [-P] $FIRST"
    exit 0
fi

# ── 문제 감지: vault에 기록 + 유사 교훈 검색 ──────────────────
if [ "$IS_PROBLEM" = "1" ] && [ "$IS_SOLUTION" = "0" ]; then
    [ -z "$FIRST" ] && exit 0
    "$LEARNINGS" add \
        --problem "$FIRST" \
        --category "$CATEGORY" \
        --severity "$SEVERITY" \
        --context "$TODAY hook-prompt" 2>/dev/null

    # 유사 교훈 + reward/punish 패턴 검색
    KEYWORDS=$(echo "$FIRST" | python3 -c "
import sys, re
text = sys.stdin.read().lower()
stopwords = {'the','is','a','이','가','을','를','에','의','로','은','는','안','못','수','것','거'}
words = re.findall(r'[a-zA-Z가-힣]{3,}', text)
print(' '.join([w for w in words if w not in stopwords][:3]))
" 2>/dev/null)

    SIMILAR=""
    for KW in $KEYWORDS; do
        RESULT=$("$LEARNINGS" search "$KW" 2>/dev/null | grep -v "^$" | grep -v "results for" | head -3)
        if [ -n "$RESULT" ]; then
            SIMILAR="$RESULT"
            break
        fi
    done

    if [ -n "$SIMILAR" ]; then
        echo "[skiro] [?] $FIRST"
        echo "[skiro/learn] 유사 교훈 발견:"
        echo "$SIMILAR"
    else
        echo "[skiro] [?] $FIRST"
    fi
    exit 0
fi

# ── 해결 감지 ─────────────────────────────────────────────────
if [ "$IS_SOLUTION" = "1" ]; then
    [ -z "$FIRST" ] && exit 0
    "$LEARNINGS" solve --solution "$FIRST" 2>/dev/null
    echo "[skiro] [v] $FIRST"
    exit 0
fi

exit 0

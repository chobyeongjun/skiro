#!/bin/sh
# skiro-hook-gate v2.1 (POSIX sh 호환)
# PreToolUse hook: Bash
# - gate 없음 → exit 2
# - 가짜 gate → exit 2  
# - 48h+ 만료 → exit 2
# - 24~48h → 경고 + 통과
# - 정상 → exit 0

SKIRO_BIN="${SKIRO_BIN:-$HOME/skiro/bin}"

INPUT=$(cat 2>/dev/null || true)
[ -z "$INPUT" ] && exit 0

COMMAND=$(echo "$INPUT" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(d.get('command', d.get('cmd', '')))
except:
    pass
" 2>/dev/null)

[ -z "$COMMAND" ] && exit 0

# ── 위험 명령어 감지 (POSIX: 개별 grep) ──────────────────────────
is_dangerous=0
for pattern in "openocd" "teensy_loader" "esptool" "st-flash" "st-link_cli" "pyocd" \
               "JLinkExe" "jlink" "nrfjprog" "skiro-flash" "dfu-util" \
               "make flash" "make upload" "ninja flash" \
               "pio run -t upload" "pio run --target upload" \
               "flash_tool" "hwtest" "hw_test"; do
    echo "$COMMAND" | grep -qiF "$pattern" && is_dangerous=1 && break
done

# cmake/program 패턴 (regex 필요)
echo "$COMMAND" | grep -qiE "cmake.*flash|program.*\.(bin|hex|elf)" && is_dangerous=1

[ "$is_dangerous" = "0" ] && exit 0

# ── gate 탐색 ─────────────────────────────────────────────────────
gate_found=0
gate_path=""
search_dir=$(pwd)
i=0
while [ $i -le 3 ]; do
    if [ -f "$search_dir/.skiro_safety_gate" ]; then
        gate_found=1
        gate_path="$search_dir/.skiro_safety_gate"
        break
    fi
    search_dir=$(dirname "$search_dir")
    i=$((i+1))
done

if [ "$gate_found" = "0" ]; then
    echo "╔══════════════════════════════════════════╗"
    echo "║  SKIRO SAFETY GATE — BLOCKED             ║"
    echo "╠══════════════════════════════════════════╣"
    echo "║  .skiro_safety_gate not found            ║"
    echo "║  Run safety analysis first               ║"
    echo "╚══════════════════════════════════════════╝"
    exit 2
fi

# ── gate 내용 검증 ───────────────────────────────────────────────
first_line=$(head -1 "$gate_path" 2>/dev/null || echo "")
if [ "$first_line" != "SAFETY_GATE_PASSED" ]; then
    echo "╔══════════════════════════════════════════╗"
    echo "║  SKIRO SAFETY GATE — INVALID             ║"
    echo "╠══════════════════════════════════════════╣"
    echo "║  Gate file content is invalid            ║"
    echo "║  Re-run: skiro safety analysis           ║"
    echo "╚══════════════════════════════════════════╝"
    exit 2
fi

if ! grep -q "analyst: skiro" "$gate_path" 2>/dev/null; then
    echo "╔══════════════════════════════════════════╗"
    echo "║  SKIRO SAFETY GATE — UNTRUSTED           ║"
    echo "╠══════════════════════════════════════════╣"
    echo "║  Gate not signed by skiro analyst        ║"
    echo "║  Re-run: skiro safety analysis           ║"
    echo "╚══════════════════════════════════════════╝"
    exit 2
fi

# ── 만료 확인 ────────────────────────────────────────────────────
gate_age=0
if [ "$(uname)" = "Darwin" ]; then
    gate_mtime=$(stat -f %m "$gate_path" 2>/dev/null || echo 0)
else
    gate_mtime=$(stat -c %Y "$gate_path" 2>/dev/null || echo 0)
fi
now=$(date +%s)
gate_age=$(( (now - gate_mtime) / 3600 ))

if [ "$gate_age" -ge 48 ]; then
    echo "╔══════════════════════════════════════════╗"
    echo "║  SKIRO SAFETY GATE — EXPIRED             ║"
    echo "╠══════════════════════════════════════════╣"
    printf "║  Gate is %dh old (limit: 48h)             ║\n" "$gate_age"
    echo "║  Re-run: skiro safety analysis           ║"
    echo "╚══════════════════════════════════════════╝"
    exit 2
elif [ "$gate_age" -gt 24 ]; then
    echo "[skiro] WARNING: Safety gate is ${gate_age}h old (expires at 48h)"
fi

echo "[skiro] Safety gate OK (${gate_age}h old) → proceeding"
exit 0

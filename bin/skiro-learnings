#!/usr/bin/env bash
# skiro-learnings v4.0 — Obsidian Vault 직접 읽기/쓰기
# learnings.jsonl 제거, vault/Research/10_Wiki/skiro-learnings.md가 Single Source of Truth
# Commands: add | solve | list | search | count | promote

# Vault 경로 탐색
find_vault() {
  for p in "${SKIRO_VAULT:-}" "$HOME/vault" "$HOME/0xhenry.dev/vault"; do
    [[ -d "$p/Research" ]] && echo "$p" && return
  done
  # symlink resolve
  [[ -L "$HOME/vault" ]] && echo "$(readlink -f "$HOME/vault")" && return
  echo ""
}

VAULT_PATH="$(find_vault)"
if [[ -z "$VAULT_PATH" ]]; then
  echo "ERROR: vault not found. Set SKIRO_VAULT or create ~/vault" >&2
  exit 1
fi

LEARNINGS_MD="$VAULT_PATH/Research/10_Wiki/skiro-learnings.md"
mkdir -p "$(dirname "$LEARNINGS_MD")"

CMD="${1:-help}"
shift || true

# ── add ──────────────────────────────────────────────────────────
if [[ "$CMD" == "add" ]]; then
  python3 - "$LEARNINGS_MD" "$@" <<'PYEOF'
import sys, re, os
from datetime import date

md_file = sys.argv[1]; args = sys.argv[2:]
kv = {}; i = 0
while i < len(args):
    if args[i].startswith('--') and i+1 < len(args):
        kv[args[i][2:]] = args[i+1]; i += 2
    else: i += 1

category = kv.get('category', 'process')
severity = kv.get('severity', 'WARNING')
problem  = kv.get('problem', kv.get('lesson', ''))
solution = kv.get('solution', '')
context  = kv.get('context', '')

if not problem: sys.exit("ERROR: --problem 필수")

# Noise filter
noise = ['<ide_opened', '<task-notification', 'files changed', 'insertions(+)',
         'chobb0@', 'hobb0@', 'b0@', '$ python3', '$ ln -s',
         'Export complete', 'dentationError', 'TensorRT: input']
if any(n in problem for n in noise):
    sys.exit(0)  # Silent skip noise
if len(problem) < 15 and not solution:
    sys.exit(0)

# Read existing file
content = ''
if os.path.exists(md_file):
    with open(md_file) as f:
        content = f.read()

# Check if this problem already exists (dedup)
if problem[:40] in content:
    print(f"[DUP] Already exists: {problem[:50]}")
    sys.exit(0)

# Category section mapping
cat_map = {
    'hardware': 'Hardware', 'safety': 'Safety', 'control': 'Control',
    'software': 'Software', 'protocol': 'Protocol', 'process': 'Process',
    'experiment': 'Experiment',
}
section_name = cat_map.get(category, category.title())

# Build new entry
today = date.today().isoformat()
if solution:
    entry = f"\n### [SOLVED] {problem}\n- **해결:** {solution}\n- **해결일:** {today}\n"
else:
    entry = f"\n### [{severity}] {problem}\n- **상태:** 미해결\n"
    if context:
        entry += f"- **컨텍스트:** {context}\n"
    entry += f"- **기록일:** {today}\n"

# Find or create section
section_header = f"\n## {section_name}\n"
if section_header.strip() in content:
    # Append entry after section header (before next ## or ---)
    pos = content.index(section_header.strip())
    # Find end of section: next ## or ---
    rest = content[pos + len(section_header.strip()):]
    next_section = len(content)
    for marker in ['\n## ', '\n---']:
        idx = rest.find(marker)
        if idx >= 0:
            next_section = min(next_section, pos + len(section_header.strip()) + idx)
    content = content[:next_section] + entry + content[next_section:]
else:
    # Create new section before "## Related" or at end
    if '## Related' in content:
        pos = content.index('## Related')
        content = content[:pos] + section_header + entry + "\n" + content[pos:]
    elif '---\n' in content and content.rstrip().endswith('---'):
        content = content.rstrip().rstrip('-').rstrip() + section_header + entry + "\n---\n"
    else:
        content += section_header + entry

# Update frontmatter date
content = re.sub(r'updated: \d{4}-\d{2}-\d{2}', f'updated: {today}', content)

with open(md_file, 'w') as f:
    f.write(content)

flag = '✓' if solution else '?'
print(f"[{flag}] [{severity}/{category}] {problem[:60]}")
if solution:
    print(f"    → {solution[:60]}")
PYEOF

# ── solve ────────────────────────────────────────────────────────
elif [[ "$CMD" == "solve" ]]; then
  python3 - "$LEARNINGS_MD" "$@" <<'PYEOF'
import sys, re, os
from datetime import date

md_file = sys.argv[1]; args = sys.argv[2:]
kv = {}; i = 0
while i < len(args):
    if args[i].startswith('--') and i+1 < len(args):
        kv[args[i][2:]] = args[i+1]; i += 2
    else: i += 1

keyword  = kv.get('keyword', '')
solution = kv.get('solution', '')
if not solution: sys.exit("ERROR: --solution 필수")

with open(md_file) as f:
    content = f.read()

today = date.today().isoformat()

# Find unsolved entry matching keyword
pattern = r'### \[(CRITICAL|WARNING|INFO)\] (.+?)(?=\n### |\n## |\n---|\Z)'
matches = list(re.finditer(pattern, content, re.DOTALL))

target = None
for m in reversed(matches):  # Most recent first
    if '미해결' in m.group(0):
        if keyword and keyword.lower() not in m.group(0).lower():
            continue
        target = m
        break

if not target:
    print("연결할 미해결 항목 없음")
    sys.exit(0)

# Replace the unsolved entry with solved version
old_block = target.group(0)
problem_title = target.group(2).strip()
new_block = f"### [SOLVED] {problem_title}\n- **해결:** {solution}\n- **해결일:** {today}\n"

content = content.replace(old_block, new_block)
content = re.sub(r'updated: \d{4}-\d{2}-\d{2}', f'updated: {today}', content)

with open(md_file, 'w') as f:
    f.write(content)

print(f"[✓ Solved] {problem_title[:60]}")
print(f"    → {solution[:60]}")
PYEOF

# ── list ─────────────────────────────────────────────────────────
elif [[ "$CMD" == "list" ]]; then
  python3 - "$LEARNINGS_MD" "$@" <<'PYEOF'
import sys, re, os

md_file = sys.argv[1]; args = sys.argv[2:]
kv = {}; i = 0
while i < len(args):
    if args[i].startswith('--') and i+1 < len(args):
        kv[args[i][2:]] = args[i+1]; i += 2
    else: i += 1

if not os.path.exists(md_file):
    print("learnings 파일 없음")
    sys.exit(0)

with open(md_file) as f:
    content = f.read()

# Parse entries
entries = []
current_cat = ''
for line in content.split('\n'):
    if line.startswith('## ') and not line.startswith('## Related'):
        current_cat = line[3:].strip().lower()
    elif line.startswith('### ['):
        m = re.match(r'### \[(SOLVED|CRITICAL|WARNING|INFO)\] (.+)', line)
        if m:
            status = 'solved' if m.group(1) == 'SOLVED' else 'unsolved'
            severity = m.group(1) if m.group(1) != 'SOLVED' else 'INFO'
            entries.append({
                'status': status, 'severity': severity,
                'problem': m.group(2), 'category': current_cat,
                'solution': ''
            })
    elif line.startswith('- **해결:**') and entries:
        entries[-1]['solution'] = line.replace('- **해결:**', '').strip()
        entries[-1]['severity'] = 'SOLVED'

# Filters
if kv.get('category'): entries = [e for e in entries if kv['category'] in e.get('category','')]
if kv.get('status'):   entries = [e for e in entries if e.get('status') == kv['status']]
if kv.get('severity'): entries = [e for e in entries if e.get('severity') == kv['severity']]

n = int(kv.get('last', 0))
if n > 0: entries = entries[-n:]

for e in entries:
    flag = '✓' if e['status'] == 'solved' else '?'
    sev = e.get('severity', '?')
    cat = e.get('category', '?')
    print(f"[{flag}][{sev}/{cat}] {e['problem']}")
    if e.get('solution'):
        print(f"    → {e['solution']}")
    elif e['status'] == 'unsolved':
        print(f"    → (미해결)")

unsolved = sum(1 for e in entries if e['status'] != 'solved')
print(f"\nTotal: {len(entries)} (미해결: {unsolved})")

# Count total unsolved in full file
all_unsolved = content.count('미해결')
if all_unsolved > unsolved:
    print(f"[!] Unsolved: {all_unsolved}")
PYEOF

# ── search ───────────────────────────────────────────────────────
elif [[ "$CMD" == "search" ]]; then
  KW="${1:-}"; [[ -z "$KW" ]] && { echo "Usage: skiro-learnings search <keyword>"; exit 1; }
  python3 - "$LEARNINGS_MD" "$KW" <<'PYEOF'
import sys, re, os

md_file, kw = sys.argv[1], sys.argv[2].lower()
if not os.path.exists(md_file):
    print("learnings 파일 없음"); sys.exit(0)

with open(md_file) as f:
    content = f.read()

# Find all ### entries containing keyword
entries = re.findall(r'(### \[.+?\].*?)(?=\n### |\n## |\n---|\Z)', content, re.DOTALL)
results = [e for e in entries if kw in e.lower()]

for e in results:
    lines = e.strip().split('\n')
    print(lines[0])
    for l in lines[1:]:
        if l.startswith('- **해결:**'):
            print(f"    → {l.replace('- **해결:**', '').strip()}")

print(f"\n{len(results)} results for '{sys.argv[2]}'")
PYEOF

# ── count ────────────────────────────────────────────────────────
elif [[ "$CMD" == "count" ]]; then
  python3 - "$LEARNINGS_MD" <<'PYEOF'
import sys, re, os

md_file = sys.argv[1]
if not os.path.exists(md_file):
    print("learnings 파일 없음"); sys.exit(0)

with open(md_file) as f:
    content = f.read()

solved = len(re.findall(r'### \[SOLVED\]', content))
critical = len(re.findall(r'### \[CRITICAL\]', content))
warning = len(re.findall(r'### \[WARNING\]', content))
info = len(re.findall(r'### \[INFO\]', content))
total = solved + critical + warning + info
unsolved = critical + warning + info

# Count by section
sections = re.findall(r'^## (\w+)', content, re.MULTILINE)
by_cat = {}
current = ''
for line in content.split('\n'):
    if line.startswith('## ') and 'Related' not in line:
        current = line[3:].strip()
    elif line.startswith('### [') and current:
        by_cat[current] = by_cat.get(current, 0) + 1

print(f"Total: {total}  (해결됨: {solved}  미해결: {unsolved})")
print(f"\nBy severity:")
print(f"  CRITICAL: {critical}")
print(f"  WARNING: {warning}")
print(f"  INFO: {info}")
print(f"  SOLVED: {solved}")
print(f"\nBy category:")
for k, v in sorted(by_cat.items()):
    print(f"  {k}: {v}")
PYEOF

# ── promote ──────────────────────────────────────────────────────
elif [[ "$CMD" == "promote" ]]; then
  echo "promote: vault 기반에서는 CHECKLIST.md에 직접 편집. skiro-learnings list --status unsolved 로 후보 확인."

# ── help ─────────────────────────────────────────────────────────
else
  echo "skiro-learnings v4.0 — Obsidian Vault 직접 읽기/쓰기"
  echo "Storage: vault/Research/10_Wiki/skiro-learnings.md"
  echo ""
  echo "Usage: skiro-learnings <cmd>"
  echo "  add     --problem <문제> [--solution <해결책>] [--category <cat>] [--severity <sev>] [--context <ctx>]"
  echo "  solve   --solution <해결책> [--keyword <검색어>]"
  echo "  list    [--last <N>] [--status solved|unsolved] [--category <cat>] [--severity CRITICAL|WARNING|INFO]"
  echo "  search  <keyword>"
  echo "  count"
  echo "  promote (CHECKLIST.md 직접 편집 안내)"
  echo ""
  echo "Vault: ${VAULT_PATH:-not found}"
  echo "Categories: safety|control|hardware|software|protocol|process|experiment"
fi

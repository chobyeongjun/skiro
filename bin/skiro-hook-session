#!/bin/sh
# skiro-hook-session v2.0 (POSIX sh 호환)
# UserPromptSubmit hook: 세션 시작 시 learnings 로드
# Fix v2.0: cwd 기반 TTL (프로젝트별 분리)

SKIRO_BIN="${SKIRO_BIN:-$HOME/skiro/bin}"
LEARNINGS="$SKIRO_BIN/skiro-learnings"
[ -x "$LEARNINGS" ] || exit 0

GLOBAL_SKIRO="$HOME/.skiro"
mkdir -p "$GLOBAL_SKIRO"
LEARNINGS_FILE="${SKIRO_LEARNINGS:-$GLOBAL_SKIRO/learnings.jsonl}"

[ -f "$LEARNINGS_FILE" ] || exit 0
[ -s "$LEARNINGS_FILE" ] || exit 0

# Fix v2.0: cwd 해시 기반 session flag (프로젝트별 TTL)
CWD_HASH=$(pwd | md5sum 2>/dev/null | cut -c1-8 || echo "global")
SESSION_FLAG="$GLOBAL_SKIRO/.session-$CWD_HASH"

if [ -f "$SESSION_FLAG" ]; then
    if [ "$(uname)" = "Darwin" ]; then
        flag_age=$(( ($(date +%s) - $(stat -f %m "$SESSION_FLAG" 2>/dev/null || echo 0)) / 60 ))
    else
        flag_age=$(( ($(date +%s) - $(stat -c %Y "$SESSION_FLAG" 2>/dev/null || echo 0)) / 60 ))
    fi
    [ "$flag_age" -lt 60 ] && exit 0
fi

touch "$SESSION_FLAG"

RECENT=$(SKIRO_LEARNINGS="$LEARNINGS_FILE" "$LEARNINGS" list --last 5 2>/dev/null)
[ -z "$RECENT" ] && exit 0

echo "─── skiro learnings (last 5) ───"
echo "$RECENT"

UNSOLVED=$(SKIRO_LEARNINGS="$LEARNINGS_FILE" "$LEARNINGS" list --status unsolved 2>/dev/null | grep -cF '[?]' || echo 0)
if [ "$UNSOLVED" -gt 0 ]; then
    echo ""
    echo "[!] Unsolved: $UNSOLVED — check before starting"
fi

PROMOTE=$(SKIRO_LEARNINGS="$LEARNINGS_FILE" "$LEARNINGS" promote 3 2>/dev/null)
if echo "$PROMOTE" | grep -qF "PROMOTE"; then
    echo ""
    echo "[CHECKLIST] Ready to promote — run: skiro-learnings promote 3 --auto"
fi

echo "────────────────────────────────"
exit 0
